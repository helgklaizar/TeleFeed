{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TeleFeed",
  "version": "1.0.0-rc.1",
  "identifier": "com.tgfeed.v3",
  "build": {
    "beforeDevCommand": "npm run dev --prefix frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "TeleFeed",
        "width": 420,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https: blob: data:; media-src 'self' asset: blob:; connect-src ipc: http://ipc.localhost http://localhost:* https://*; font-src 'self' https://fonts.gstatic.com",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "/tmp/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "resources": [
      "../frontend/node_modules/@prebuilt-tdlib/darwin-arm64/libtdjson.dylib"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}